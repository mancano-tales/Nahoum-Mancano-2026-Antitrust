# ==============================================================================
# .gitattributes — Forçar quebra de linha LF (Unix) para scripts e hooks
#
# Isso impede falhas de execução no Windows com shebangs Unix.
# ==============================================================================

# Forçar quebra de linha Unix (LF) em todos os scripts e templates de hooks
hooks/* text eol=lf
*.sh text eol=lf
setup.sh text eol=lf
